---
const links = [
  { label: "Inicio",   href: "#inicio" },
  { label: "Menú",     href: "#menu" },
  { label: "Nosotros", href: "#nosotros" },
  { label: "Galería",  href: "#galeria" },
  { label: "Contacto", href: "#contacto" },
];
---

<header class="fixed top-0 left-0 right-0 z-100 transition-[background,box-shadow] duration-300" id="navbar">

  <div class="max-w-300 mx-auto px-8 py-3.5 flex items-center gap-8 shadow-cream-dark">

    <a href="#inicio" class="flex items-center gap-2 shrink-0 no-underline">
      <span class="text-2xl">☕</span>
      <span class="font-display text-2xl font-bold text-bark-dark tracking-wide">La Tinta Cafebrería</span>
    </a>

    <nav class="hidden lg:flex gap-1 ml-auto items-center">
      {links.map(l => (
        <a
          href={l.href}
          class="font-ui text-[0.82rem] font-semibold uppercase mix-blend-darken tracking-[0.04em] text-bark
                 px-2 py-1.5 rounded no-underline  text-shadow-ink hover:text-bark hover:bg-cream-dark transition-colors duration-200"
        >
          {l.label}
        </a>
      ))}
    </nav>

    <a
      href="#contacto"
      class="hidden lg:inline-block font-ui text-[0.82rem] font-semibold uppercase tracking-[0.06em]
             text-cream bg-bark px-5 py-2.5 rounded shrink-0 no-underline
             hover:bg-bark-dark hover:-translate-y-px transition-all duration-200"
    >
      Reservar mesa
    </a>

    <button
      id="burger"
      aria-label="Abrir menú"
      class="hidden ml-auto sm:flex flex-col gap-1.5 bg-transparent border-none cursor-pointer p-1"
    >
      <span class="block w-6 h-0.5 bg-bark-dark rounded"></span>
      <span class="block w-6 h-0.5 bg-bark-dark rounded"></span>
      <span class="block w-6 h-0.5 bg-bark-dark rounded"></span>
    </button>
  </div>

  <div id="mobile-menu" class="hidden flex-col px-8 pb-6 pt-2 bg-cream border-t border-parchment gap-1">
    {links.map(l => (
      <a href={l.href} class="font-ui text-base font-semibold uppercase tracking-[0.04em] text-ink-soft py-2.5 px-2 border-b border-parchment no-underline">
        {l.label}
      </a>
    ))}
    <a href="#contacto" class="font-ui text-[0.82rem] font-semibold uppercase tracking-[0.06em] text-cream bg-bark px-5 py-2.5 rounded text-center mt-3 no-underline">
      Reservar mesa
    </a>
  </div>
</header>

<script>
  const navbar     = document.getElementById('navbar')!;
  const anchors = document.getElementsByTagName('');
  const burger     = document.getElementById('burger')!;
  const mobileMenu = document.getElementById('mobile-menu')!;

  window.addEventListener('scroll', () => {
    if (window.scrollY > 40) {
      navbar.style.cssText = 'background:rgba(250,245,237,0.96);backdrop-filter:blur(8px);box-shadow:0 2px 20px rgba(62,42,20,0.22)';
    } else {
      navbar.style.cssText = '';
    }
  });

  burger.addEventListener('click', () => {
    const isOpen = mobileMenu.classList.contains('flex');
    mobileMenu.classList.toggle('hidden', isOpen);
    mobileMenu.classList.toggle('flex', !isOpen);
  });

  mobileMenu.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', () => {
      mobileMenu.classList.add('hidden');
      mobileMenu.classList.remove('flex');
    });
  });
</script>