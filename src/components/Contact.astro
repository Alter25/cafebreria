---
const info = [
  { icon: "📍", label: "Dirección", value: "Av Morelos 559 pte, Primero de Cobián Centro, 27000 Torreón, Coah." },
  { icon: "🕐", label: "Horario",   value: "Lun–Vie: 10am – 8pm\nSáb: 10am – 8pm" },
  { icon: "📞", label: "Teléfono",  value: "+52 871 711 2260" },
  { icon: "✉️", label: "Correo",    value: "latintacafebreria@gmail.com" },
];
---

<section class="relative py-28 px-8 bg-[#1a1412] overflow-hidden" id="contacto">
  <div class="absolute top-0 left-0 right-0 h-1 bg-linear-to-r from-orange-600 via-stone-400 to-orange-600"></div>

  <div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-12 items-start">
    
    <div>
      <p class="text-xs font-semibold tracking-widest uppercase text-white/60 mb-3">Encuéntranos</p>
      <h2 class="text-4xl font-bold text-white mb-3">Ven a visitarnos</h2>
      <p class="text-white/75 mb-8">
        Siempre hay un lugar disponible y una taza lista.<br />
        Si quieres reservar para grupos, escríbenos.
      </p>

      <div class="flex flex-col gap-5 mb-8">
        {info.map((item) => (
          <div class="flex gap-3 items-start">
            <span class="text-xl">{item.icon}</span>
            <div>
              <p class="text-[10px] font-bold uppercase tracking-widest text-white/50 mb-0.5">{item.label}</p>
              <p class="text-sm text-white whitespace-pre-line">{item.value}</p>
            </div>
          </div>
        ))}
      </div>

      <div class="flex gap-3">
        <a href="https://www.instagram.com/latintacafebreria" class="flex items-center justify-center w-10 h-10 rounded-full border border-white/20 text-white hover:bg-orange-700 transition-all">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="0.5" fill="currentColor"/></svg>
        </a>
        <a href="https://www.facebook.com/latintacafebreria/" class="flex items-center justify-center w-10 h-10 rounded-full border border-white/20 text-white hover:bg-orange-700 transition-all">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"><path fill="currentColor" d="M12 2.04c-5.5 0-10 4.49-10 10.02c0 5 3.66 9.15 8.44 9.9v-7H7.9v-2.9h2.54V9.85c0-2.51 1.49-3.89 3.78-3.89c1.09 0 2.23.19 2.23.19v2.47h-1.26c-1.24 0-1.63.77-1.63 1.56v1.88h2.78l-.45 2.9h-2.33v7a10 10 0 0 0 8.44-9.9c0-5.53-4.5-10.02-10-10.02"/></svg>
        </a>
        </div>
    </div>

    <div class="bg-white/5 border border-white/10 rounded-xl p-8 backdrop-blur-sm">
      <h3 class="text-lg font-bold text-white mb-6">Envíanos un mensaje</h3>
      <form id="contact-form">
         <button type="submit" class="w-full bg-orange-700 text-white py-3 rounded-md font-bold hover:bg-orange-600 transition-all">
           Enviar mensaje
         </button>
      </form>
    </div>
  </div>
</section>