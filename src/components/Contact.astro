---
const info = [
  { icon: "📍", label: "Dirección", value: "Calle Hidalgo 214, Centro Histórico" },
  { icon: "🕐", label: "Horario",   value: "Lun–Vie: 7am – 9pm\nSáb–Dom: 8am – 10pm" },
  { icon: "📞", label: "Teléfono",  value: "+52 871 123 4567" },
  { icon: "✉️", label: "Correo",    value: "hola@lalena.cafe" },
];
---

<section class="relative py-28 px-8 bg-bark-dark overflow-hidden" id="contacto">

  <!-- Línea superior decorativa -->
  <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-ember via-bark-light to-ember"></div>

  <div class="max-w-[1100px] mx-auto grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-20 items-start">

    <!-- Info -->
    <div>
      <p class="font-ui text-[0.78rem] font-semibold tracking-[0.18em] uppercase text-parchment/60 mb-3 reveal">
        Encuéntranos
      </p>
      <h2 class="font-display text-[clamp(2rem,3.5vw,2.8rem)] font-bold text-cream mb-3 reveal">
        Ven a visitarnos
      </h2>
      <p class="font-body text-parchment/75 text-base leading-relaxed mb-8 reveal">
        Siempre hay un lugar disponible y una taza lista.<br />
        Si quieres reservar para grupos, escríbenos.
      </p>

      <div class="flex flex-col gap-5 mb-8">
        {info.map((item, i) => (
          <div class="flex gap-3 items-start reveal" style={`transition-delay: ${i * 0.1}s`}>
            <span class="text-[1.1rem] shrink-0 mt-0.5">{item.icon}</span>
            <div>
              <p class="font-ui text-[0.68rem] font-bold uppercase tracking-[0.1em] text-parchment/55 mb-0.5">
                {item.label}
              </p>
              <p class="font-ui text-[0.92rem] text-cream leading-snug whitespace-pre-line">
                {item.value}
              </p>
            </div>
          </div>
        ))}
      </div>

      <!-- Social links -->
      <div class="flex gap-3 reveal">
        {[
          { label: "Instagram", path: "M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z" },
        ].map(() => null)}

        <!-- Instagram -->
        <a href="#" aria-label="Instagram"
           class="flex items-center justify-center w-10 h-10 rounded-full border border-white/20 text-parchment
                  hover:bg-ember hover:border-ember hover:text-white hover:-translate-y-0.5 transition-all duration-200">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/>
            <circle cx="17.5" cy="6.5" r="0.5" fill="currentColor"/>
          </svg>
        </a>

        <!-- Facebook -->
        <a href="#" aria-label="Facebook"
           class="flex items-center justify-center w-10 h-10 rounded-full border border-white/20 text-parchment
                  hover:bg-ember hover:border-ember hover:text-white hover:-translate-y-0.5 transition-all duration-200">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
          </svg>
        </a>

        <!-- TikTok -->
        <a href="#" aria-label="TikTok"
           class="flex items-center justify-center w-10 h-10 rounded-full border border-white/20 text-parchment
                  hover:bg-ember hover:border-ember hover:text-white hover:-translate-y-0.5 transition-all duration-200">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.34 6.34 0 100 12.68 6.34 6.34 0 006.33-6.34V8.69a8.18 8.18 0 004.78 1.52V6.77a4.85 4.85 0 01-1.01-.08z"/>
          </svg>
        </a>
      </div>
    </div>

    <!-- Formulario -->
    <div class="bg-white/5 border border-white/10 rounded-xl p-10 backdrop-blur-sm reveal">
      <h3 class="font-display text-[1.3rem] font-bold text-cream mb-7">
        Envíanos un mensaje
      </h3>

      <form id="contact-form" novalidate>
        <div class="flex flex-col gap-1.5 mb-5">
          <label class="font-ui text-[0.75rem] font-semibold uppercase tracking-[0.08em] text-parchment/65">
            Nombre
          </label>
          <input
            type="text" name="name" placeholder="Tu nombre" required
            class="bg-white/7 border border-white/15 rounded-md px-4 py-3 font-ui text-[0.92rem] text-cream
                   placeholder:text-white/30 outline-none focus:border-bark-light focus:bg-white/10 transition-colors duration-200"
          />
        </div>

        <div class="flex flex-col gap-1.5 mb-5">
          <label class="font-ui text-[0.75rem] font-semibold uppercase tracking-[0.08em] text-parchment/65">
            Correo
          </label>
          <input
            type="email" name="email" placeholder="correo@ejemplo.com" required
            class="bg-white/7 border border-white/15 rounded-md px-4 py-3 font-ui text-[0.92rem] text-cream
                   placeholder:text-white/30 outline-none focus:border-bark-light focus:bg-white/10 transition-colors duration-200"
          />
        </div>

        <div class="flex flex-col gap-1.5 mb-6">
          <label class="font-ui text-[0.75rem] font-semibold uppercase tracking-[0.08em] text-parchment/65">
            Mensaje
          </label>
          <textarea
            name="message" rows="4" placeholder="¿En qué podemos ayudarte?" required
            class="bg-white/7 border border-white/15 rounded-md px-4 py-3 font-ui text-[0.92rem] text-cream
                   placeholder:text-white/30 outline-none focus:border-bark-light focus:bg-white/10
                   transition-colors duration-200 resize-y"
          ></textarea>
        </div>

        <button
          type="submit"
          class="w-full bg-ember text-white border-none rounded-md py-3.5 font-ui text-[0.88rem] font-bold
                 uppercase tracking-[0.07em] cursor-pointer flex items-center justify-center gap-2
                 hover:bg-ember-light hover:-translate-y-px transition-all duration-200"
        >
          <span>Enviar mensaje</span>
          <span id="btn-arrow" class="text-base transition-transform duration-200">→</span>
        </button>

        <p id="form-success" class="hidden mt-4 text-center font-ui text-[0.88rem] text-sage
                                    bg-sage/15 rounded-md py-2.5 px-4">
          ¡Mensaje recibido! Te respondemos pronto ☕
        </p>
      </form>
    </div>

  </div>
</section>

<script>
  const form    = document.getElementById('contact-form') as HTMLFormElement;
  const success = document.getElementById('form-success')!;
  const arrow   = document.getElementById('btn-arrow')!;

  form?.addEventListener('submit', e => {
    e.preventDefault();
    success.classList.remove('hidden');
    form.reset();
    setTimeout(() => success.classList.add('hidden'), 4000);
  });

  form?.querySelector('button')?.addEventListener('mouseenter', () => {
    arrow.style.transform = 'translateX(4px)';
  });
  form?.querySelector('button')?.addEventListener('mouseleave', () => {
    arrow.style.transform = '';
  });
</script>