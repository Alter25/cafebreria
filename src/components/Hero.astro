---
---

<section class="relative min-h-svh flex items-center overflow-hidden" id="inicio">

  <!-- Imagen de fondo -->
  <div
    class="absolute inset-0 bg-cover bg-center scale-[1.04] animate-slow-zoom"
    style="background-image: url('https://images.unsplash.com/photo-1495474472287-4d71bcdd2085?w=1600&q=80')"
  ></div>

  <!-- Overlay -->
  <div class="absolute inset-0 bg-gradient-to-br from-bark-dark/75 via-bark-dark/50 to-bark-dark/65 z-[1]"></div>

  <!-- Contenido -->
  <div class="relative z-[2] max-w-[1200px] mx-auto px-8 pt-32 pb-16 w-full">

    <p class="font-ui text-[0.78rem] font-semibold tracking-[0.18em] uppercase text-parchment/80 mb-5 animate-fade-up [animation-delay:0.2s]">
      Café artesanal · Desde 2010
    </p>

    <h1 class="font-display text-[clamp(3.2rem,7vw,6rem)] font-bold leading-[1.1] text-white mb-6 animate-fade-up [animation-delay:0.4s]">
      Donde el café<br />
      <em class="text-parchment italic">cuenta historias</em>
    </h1>

    <p class="font-body text-[clamp(1rem,2vw,1.15rem)] text-white/80 max-w-[48ch] mb-10 animate-fade-up [animation-delay:0.6s]">
      Granos de origen, pan horneado cada mañana y un rincón cálido
      que te espera sin prisa.
    </p>

    <div class="flex gap-4 flex-wrap animate-fade-up [animation-delay:0.8s]">
      <a
        href="#menu"
        class="font-ui text-[0.88rem] font-semibold uppercase tracking-[0.07em] no-underline
               text-white bg-ember px-8 py-3.5 rounded
               shadow-[0_4px_18px_rgba(192,82,42,0.4)]
               hover:bg-ember-light hover:-translate-y-0.5 hover:shadow-[0_6px_24px_rgba(192,82,42,0.5)]
               transition-all duration-200"
      >
        Ver nuestro menú
      </a>
      <a
        href="#nosotros"
        class="font-ui text-[0.88rem] font-semibold uppercase tracking-[0.07em] no-underline
               text-white bg-transparent border border-white/50 px-8 py-3.5 rounded
               hover:bg-white/10 hover:border-white hover:-translate-y-0.5
               transition-all duration-200"
      >
        Nuestra historia
      </a>
    </div>
  </div>

  <!-- Badge de horario -->
  <div class="absolute bottom-14 right-12 z-[2] flex flex-col items-center justify-center
              bg-cream rounded-full w-[90px] h-[90px] shadow-[0_4px_20px_rgba(62,42,20,0.22)]
              animate-scale-in [animation-delay:1s]
              max-sm:hidden">
    <span class="font-ui text-[0.65rem] font-semibold uppercase tracking-[0.1em] text-sage">Abierto</span>
    <span class="font-display text-[0.88rem] font-bold text-bark-dark">7am–9pm</span>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-[2] [animation:fadeIn_1s_ease_1.5s_both]">
    <span class="block w-px h-12 bg-gradient-to-b from-white/80 to-transparent animate-scroll-pulse"></span>
  </div>

</section>